<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE xml>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="wx250s">

  <xacro:property name="L1" value="0.05" />
  <xacro:property name="L1radius" value="0.04" />
  <xacro:property name="L2" value="0.25" />
  <xacro:property name="L2radius" value="0.03" />
  <xacro:property name="L3" value="0.17155" />
  <xacro:property name="L3radius" value="0.02" />
  <xacro:property name="L4" value="0.07845" />
  <xacro:property name="L5" value="0.065" />
  <xacro:property name="L6" value="0.066" />
  <xacro:property name="eesize" value="0.05" />
  <xacro:property name="J1MIN" value="${-pi}" />
  <xacro:property name="J1MAX" value="${pi}" />
  <xacro:property name="J2MIN" value="-0.08" />
  <xacro:property name="J2MAX" value="0.08" />
  <xacro:property name="J3MIN" value="${-pi}" />
  <xacro:property name="J3MAX" value="${pi}" />

  <material name="blue">
    <color rgba="0.2 0.4 0.65 1" />
  </material>

  <material name="yellow">
    <color rgba="1 0.85 0 1" />
  </material>

  <link name="world" />

  <link name="base" />

  <link name="link1">
    <visual name="link1">
      <origin xyz="0 0 ${L1/2}" />
      <geometry>
        <cylinder radius="${L1radius}" length="${L1}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>

  <link name="link2">
    <visual name="link2">
      <origin xyz="0 0 ${L2/2}" />
      <geometry>
        <cylinder radius="${L2radius}" length="${L2}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>

  <link name="st">
    <visual name="st">
      <origin xyz="0.025 0 0" rpy="0 ${pi/2} 0" />
      <geometry>
        <cylinder radius="${L2radius}" length="${0.05}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>

  <link name="link3">
    <visual name="link3">
      <origin xyz="${L3/2} 0 0" rpy="0 ${pi/2} 0" />
      <geometry>
        <cylinder radius="${L3radius}" length="${L3}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>

  <link name="link4">
    <visual name="link4">
      <origin xyz="${L4/2} 0 0" rpy="0 ${pi/2} 0" />
      <geometry>
        <cylinder radius="${L2radius}" length="${L4}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>

  <link name="link5">
    <visual name="link5">
      <origin xyz="${L5/2} 0 0" rpy="0 ${pi/2} 0" />
      <geometry>
        <cylinder radius="${L3radius}" length="${L5}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>

  <link name="link6">
    <visual name="link6">
      <origin xyz="${L6/2} 0 0" rpy="0 ${pi/2} 0" />
      <geometry>
        <cylinder radius="${L2radius}" length="${L6}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>

  <link name="ee">
    <visual name="ee">
      <origin xyz="${-eesize/2} 0 0" />
      <geometry>
        <box size="${eesize} ${eesize} ${eesize}" />
      </geometry>
      <material name="yellow" />
    </visual>
  </link>

  <joint name="base_in_world" type="fixed">
    <parent link="world" />
    <child link="base" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <joint name="waist" type="revolute">
    <parent link="base" />
    <child link="link1" />
    <origin xyz="0 0 0.06025" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="${-pi}" upper="${pi}" effort="1" velocity="1" />
  </joint>

  <joint name="shoulder" type="revolute">
    <parent link="link1" />
    <child link="link2" />
    <origin xyz="0 0 0.05" rpy="0 0 0" />
    <axis xyz="0 -1 0" />
    <limit lower="${(-108*pi)/180}" upper="${(114*pi)/180}" effort="1" velocity="1" />
  </joint>

  <joint name="shoulder_top" type="fixed">
    <parent link="link2" />
    <child link="st" />
    <origin xyz="0 0 0.25" rpy="0 0 0" />
  </joint>

  <joint name="elbow" type="revolute">
    <parent link="st" />
    <child link="link3" />
    <origin xyz="0.05 0 0" rpy="0 0 0" />
    <axis xyz="0 -1 0" />
    <limit lower="${(-123*pi)/180}" upper="${(92*pi)/180}" effort="1" velocity="1" />
  </joint>

  <joint name="forearm_roll" type="revolute">
    <parent link="link3" />
    <child link="link4" />
    <origin xyz="0.17155 0 0" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="${-pi}" upper="${pi}" effort="1" velocity="1" />
  </joint>

  <joint name="wrist_angle" type="revolute">
    <parent link="link4" />
    <child link="link5" />
    <origin xyz="0.07845 0 0" rpy="0 0 0" />
    <axis xyz="0 -1 0" />
    <limit lower="${(-100*pi)/180}" upper="${(123*pi)/180}" effort="1" velocity="1" />
  </joint>

  <joint name="wrist_rotate" type="revolute">
    <parent link="link5" />
    <child link="link6" />
    <origin xyz="0.065 0 0" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="${-pi}" upper="${pi}" effort="1" velocity="1" />
  </joint>

  <joint name="ee_in_link3" type="fixed">
    <parent link="link6" />
    <child link="ee" />
    <origin xyz="0.10915 0 0" rpy="0 0 0" />
  </joint>

</robot>
